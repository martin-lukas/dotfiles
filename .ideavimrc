packadd matchit

" Mappings
let mapleader = " "
nnoremap <C-L> :nohlsearch<CR><C-L>
nnoremap <Leader>d :bd<CR>

" Configuration
set relativenumber
set hlsearch
set incsearch
set colorcolumn=100
set scrolloff=5

" If the file was opened before, jump to the last viewed/edited line in it.
if has("autocmd")
  autocmd BufReadPost * if line("'\"") > 0 && line("'\"") <= line("$") | exe "normal! g`\"" | endif
endif

