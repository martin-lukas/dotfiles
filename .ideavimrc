" ----- Plugins ----- "
packadd matchit


" ----- Mappings ----- "
inoremap jk <Esc>
noremap <C-L> :nohlsearch<CR><C-L>
let mapleader = " "
noremap <Leader>b :ls<CR>:b<Space>
noremap <Leader>d :bd<CR>
noremap <Leader>q :q<CR>
noremap <Leader>w :w<CR>
noremap <Leader>a <Action>(Vcs.ShowHistoryForBlock)
noremap <Leader>e <Action>(RecentFiles)
noremap <Leader>j <Action>(QuickJavaDoc)
noremap <Leader>x <Action>(SelectInProjectView)


" ----- Settings ----- "
set relativenumber
set hlsearch
set incsearch
set colorcolumn=100
set scrolloff=5


" If the file was opened before, jump to the last viewed/edited line in it.
if has("autocmd")
  autocmd BufReadPost *
      \ if line("'\"") > 0 && line("'\"") <= line("$") |
      \     exe "normal! g`\"" |
      \ endif
endif

