[init]
    defaultBranch = main

[core]
    autocrlf = input        # convert CRLF to LF on commit, leave LF alone on checkout
    editor = vim

[color]
    ui = auto

[user]
    name = Martin Lukas
    email = martinlukasgit@protonmail.com

[push]
    autoSetupRemote = true  # auto-set upstream on first push, no need for -u

[pull]
    rebase = true           # rebase instead of merge on pull, keeps history linear

[alias]
    st    = status
    ss    = st -sb
    lg    = log --oneline --graph --decorate --all
    d     = diff --unified=10 HEAD
    a     = add -A
    c     = commit
    amend = commit --amend --no-edit
    ac    = !git a && git c
    aa    = !git a && git amend
    undo  = reset --soft HEAD~1
    wipe  = reset --hard HEAD
    ri    = rebase -i
    rc    = rebase --continue
    pu    = push -u origin
    p     = push origin
    pf    = p --force-with-lease
    f     = fetch
    pl    = pull --rebase

[include]
    path = ~/.gitconfig.local
