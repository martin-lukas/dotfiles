[init]
    defaultBranch = main

[core]
    autocrlf = input        # convert CRLF to LF on commit, leave LF alone on checkout
    editor = vim

[color]
    ui = auto

[user]
    name = Martin Lukas
    email = martinlukasgit@protonmail.com

[push]
    autoSetupRemote = true  # auto-set upstream on first push, no need for -u

[pull]
    rebase = true           # rebase instead of merge on pull, keeps history linear

[alias]
    st  = status
    ss  = st -sb                        # short status with branch info
    lg  = log --oneline --graph --decorate --all  # visual branch graph
    d   = diff --unified=10 HEAD        # diff against last commit, more context lines
    a   = add -A
    c   = commit
    ac  = !git a && git c               # stage all and commit in one step
    undo = reset --soft HEAD~1          # undo last commit, keep changes staged
    wipe = reset --hard HEAD            # discard all local changes
    ri  = rebase -i
    rc  = rebase --continue
    pu  = push -u origin                # push and set upstream
    p   = push origin
    pf  = p --force-with-lease          # safer force push — fails if remote has new commits
    f   = fetch
    pl  = pull --rebase

[include]
    path = ~/.gitconfig.local
