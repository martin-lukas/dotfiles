# Machine-specific config (not tracked in git)
Include ~/.ssh/config.local

Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/github

# Local network
Host homeserver
    HostName 192.168.1.10
    User martin
    IdentityFile ~/.ssh/homeserver

# Tailscale
Host ts-homeserver
    HostName homeserver
    User martin
    IdentityFile ~/.ssh/homeserver
