# Machine-specific config (not tracked in git)
Include ~/.ssh/config.local

Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/github
    AddKeysToAgent yes

# Local network
Host homeserver
    HostName 192.168.1.35
    User root
    IdentityFile ~/.ssh/homeserver

Host jellyfin
    HostName 192.168.1.36
    User martin
    IdentityFile ~/.ssh/jellyfin

Host nixos
    HostName 192.168.1.37
    User martin
    IdentityFile ~/.ssh/nixos

# Tailscale
Host ts-homeserver
    HostName homeserver
    User root
    IdentityFile ~/.ssh/ts-homeserver

Host ts-jellyfin
    HostName jellyfin
    User martin
    IdentityFile ~/.ssh/ts-jellyfin

Host ts-nixos
    HostName homeserver-nixos
    User martin
    IdentityFile ~/.ssh/ts-nixos
